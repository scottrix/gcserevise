      { "name": "Paper 1", "title": "Key concepts in biology, Cells and control, Genetics, Natural selection, Health and disease", "duration": "1h 45m", "marks": 100, "weighting": 50 },
      { "name": "Paper 2", "title": "Key concepts in biology, Ecosystems, Adaptation, Inheritance, Hormones, Reproduction", "duration": "1h 45m", "marks": 100, "weighting": 50 }
    ],
    "OCR": [
      { "name": "Paper 1", "title": "Community level systems, Ecosystems, Inheritance, Variation and evolution, The human body, Disease and drugs", "duration": "1h 45m", "marks": 90, "weighting": 50 },
      { "name": "Paper 2", "title": "Community level systems, Ecosystems, Inheritance, Variation and evolution, The human body, Disease and drugs, Photosynthesis, Respiration, Homeostasis", "duration": "1h 45m", "marks": 90, "weighting": 50 }
