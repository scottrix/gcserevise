{
  "subject": "English Literature",
  "id": "english-literature",
  "examBoards": ["AQA", "Edexcel", "OCR", "Eduqas", "CCEA"],
  "papers": {
    "AQA": [
      { "name": "Paper 1", "title": "Shakespeare and the 19th-century novel", "duration": "1h 45m", "marks": 64, "weighting": 40 },
      { "name": "Paper 2", "title": "Modern texts and poetry", "duration": "2h 15m", "marks": 96, "weighting": 60 }
    ],
    "Edexcel": [
      { "name": "Paper 1", "title": "Shakespeare and Post-1914 Literature", "duration": "1h 45m", "marks": 64, "weighting": 50 },
      { "name": "Paper 2", "title": "19th Century Novel and Poetry since 1789", "duration": "2h 15m", "marks": 96, "weighting": 50 }
    ],
    "OCR": [
      { "name": "Paper 1", "title": "Exploring Modern and Literary Heritage Texts", "duration": "2h", "marks": 80, "weighting": 50 },
      { "name": "Paper 2", "title": "Exploring Poetry and Shakespeare", "duration": "2h 30m", "marks": 80, "weighting": 50 }
    ],
    "Eduqas": [
      { "name": "Paper 1", "title": "Shakespeare and Poetry", "duration": "2h", "marks": 80, "weighting": 40 },
      { "name": "Paper 2", "title": "Post-1914 Prose/Drama, 19th Century Prose and Unseen Poetry", "duration": "2h 30m", "marks": 120, "weighting": 60 }
    ],
    "CCEA": [
      { "name": "Unit 1", "title": "The Study of Prose", "duration": "1h 45m", "marks": 60, "weighting": 30 },
      { "name": "Unit 2", "title": "The Study of Drama and Poetry", "duration": "2h", "marks": 60, "weighting": 30 },
      { "name": "Unit 3", "title": "The Study of Shakespeare", "duration": "1h 45m", "marks": 80, "weighting": 40 }
    ]
  },
  "assessmentObjectives": [
    { "id": "AO1", "description": "Read, understand and respond to texts. Maintain a critical style and develop an informed personal response. Use textual references, including quotations, to support and develop interpretations.", "weighting": "25-35%" },
    { "id": "AO2", "description": "Analyse the language, form and structure used by a writer to create meanings and effects, using relevant subject terminology where appropriate.", "weighting": "30-40%" },
    { "id": "AO3", "description": "Show understanding of the relationships between texts and the contexts in which they were written.", "weighting": "15-25%" },
    { "id": "AO4", "description": "Use a range of vocabulary and sentence structures for clarity, purpose and effect, with accurate spelling and punctuation.", "weighting": "5-10%" }
  ],
  "settexts": {
    "shakespeare": {
      "name": "Shakespeare Plays",
      "description": "All boards offer a choice of Shakespeare plays for detailed study",
      "common": ["Macbeth", "Romeo and Juliet", "The Tempest", "The Merchant of Venice", "Much Ado About Nothing", "Julius Caesar"],
      "additional": {
        "Edexcel": ["Henry V"],
        "OCR": ["Henry V", "Twelfth Night", "Richard III"],
        "Eduqas": ["Henry V", "Twelfth Night"],
        "CCEA": ["Henry V", "Twelfth Night"]
      }
    },
    "nineteenth-century": {
      "name": "19th Century Novels",
      "description": "Students study one 19th century novel in detail",
      "common": ["Dr Jekyll and Mr Hyde", "A Christmas Carol", "Great Expectations", "Jane Eyre", "Frankenstein", "Pride and Prejudice", "The Sign of Four"],
      "additional": {
        "OCR": ["The War of the Worlds", "The Picture of Dorian Gray"],
        "Eduqas": ["The War of the Worlds"],
        "CCEA": ["The War of the Worlds"]
      }
    },
    "modern-texts": {
      "name": "Modern Texts (Post-1914)",
      "description": "Students study one modern text - drama or prose",
      "drama": ["An Inspector Calls", "Blood Brothers", "The History Boys", "DNA", "The Curious Incident of the Dog in the Night-Time", "A Taste of Honey"],
      "prose": ["Lord of the Flies", "Animal Farm", "Never Let Me Go", "Anita and Me", "Pigeon English"],
      "additional": {
        "AQA": ["Princess & The Hustler", "Leave Taking", "My Name is Leon"],
        "OCR": ["The Crucible", "To Kill a Mockingbird", "Of Mice and Men"],
        "Eduqas": ["The Crucible", "To Kill a Mockingbird", "Of Mice and Men", "Things Fall Apart"],
        "Edexcel": ["Things Fall Apart"]
      }
    },
    "poetry": {
      "name": "Poetry Anthologies",
      "description": "Students study a poetry anthology and respond to unseen poetry",
      "anthologies": {
        "AQA": ["Love and Relationships", "Power and Conflict", "Worlds and Lives"],
        "Edexcel": ["Time and Place", "Relationships", "Conflict"],
        "OCR": ["Toward a World Unknown", "Love and Relationships", "Conflict"],
        "Eduqas": ["Poetry Anthology (18 poems)"]
      }
    }
  },
